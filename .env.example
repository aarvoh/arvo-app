# Copy this file to .env and fill in your own values.
# Never commit .env — it is gitignored.

# Anthropic API key — get yours at console.anthropic.com
ANTHROPIC_API_KEY=

# Python brain WebSocket URL (local dev)
VITE_BRAIN_URL=ws://localhost:8765/ws

# Spotify OAuth client ID — create a free app at developer.spotify.com
# Add this Redirect URI in your Spotify app settings: http://localhost:5174/
VITE_SPOTIFY_CLIENT_ID=
